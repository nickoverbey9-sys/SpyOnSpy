# ─── SpyOnSpy environment template ─────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit the real .env, creds.txt, or any token.
# All BOT_* / TRADIER_* defaults documented in server/bot/config.ts header.

# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Tradier (live trading is OFF unless ALL four guards below are satisfied) ──
# 1) explicit opt-in flag
TRADIER_ENABLE_LIVE_TRADING=false
# 2) brokerage account id
TRADIER_ACCOUNT_ID=
# 3) bearer token (server-side only — never expose to the client)
TRADIER_TOKEN=
# 4) per-request body must include { confirmLiveOrder: true }

# Optional base URL override. Defaults to sandbox unless live is fully enabled.
# TRADIER_BASE_URL=https://api.tradier.com
# TRADIER_BASE_URL=https://sandbox.tradier.com

# ─── Autonomous (hands-off) trading — HIGH RISK, defaults OFF ─────────────────
TRADIER_AUTO_TRADE=false

# ─── Risk guardrails (safe small-account defaults; uncomment to override) ─────
# BOT_PREFERRED_CONTRACTS_PER_TRADE=4
# BOT_MIN_CONTRACTS_PER_TRADE=1
# BOT_MAX_CONTRACTS_PER_TRADE=0
# BOT_MAX_OPEN_POSITIONS=2
# BOT_MAX_TRADES_PER_DAY=6
# BOT_MAX_DAILY_LOSS=200
# BOT_MAX_LOSS_PER_TRADE=100
# BOT_ENFORCE_MAX_LOSS_PER_TRADE=true
# BOT_ACCOUNT_START_BALANCE=1326.24
# BOT_PDT_GUARD_ENABLED=true
# BOT_KILL_SWITCH=false

# ─── Exit model (stop / breakeven / profit-lock / trailing runner) ────────────
# BOT_STOP_LOSS_FRACTION=0.20
# BOT_BREAKEVEN_ARM_FRACTION=0.10
# BOT_PROFIT_LOCK_ARM_FRACTION=0.15
# BOT_PROFIT_LOCK_PROFIT_FRACTION=0.05
# BOT_TRAIL_START_FRACTION=0.25
# BOT_TRAIL_GIVEBACK_FRACTION=0.15

# ─── Entry filters & contract selection ───────────────────────────────────────
# BOT_MIN_CONFIDENCE=55
# BOT_AUTO_MIN_CONFIDENCE=70
# BOT_MIN_UNUSUAL_SCORE=60
# BOT_MIN_OPTION_PREMIUM=0.15
# BOT_MAX_SPREAD_PCT=0.30
# BOT_CONTRACT_SELECTION_MODE=best_liquid
# BOT_OTM_STRIKES=1

# ─── Time-of-day / data freshness ─────────────────────────────────────────────
# BOT_ENTRY_TIME_GUARD_ENABLED=true
# BOT_ENTRY_BLACKOUT_OPEN_MIN=15
# BOT_ENTRY_BLACKOUT_CLOSE_MIN=15
# BOT_FLATTEN_HOUR_CT=14
# BOT_FLATTEN_MINUTE_CT=30
# BOT_FLATTEN_TIME_CT_HOUR=14
# BOT_FLATTEN_TIME_CT_MINUTE=55
# BOT_REQUIRE_FRESH_DATA=true
# BOT_MAX_CANDLE_STALENESS_SEC=120
# BOT_NEWS_BLACKOUT_MINUTES=10

# ─── Persistent kill-switch file (defaults to .data/kill-switch.json) ─────────
# BOT_KILL_SWITCH_FILE=.data/kill-switch.json
